# Use a Python base image (for scripts that consume JSON)
FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Working directory
WORKDIR /opt/whatsmyname

# Clone WhatsMyName repo
RUN git clone https://github.com/WebBreacher/WhatsMyName.git .

# Install any Python helpers (optional; repo has some)
RUN pip install --no-cache-dir requests

# Default command (show JSON help)
ENTRYPOINT ["cat", "web_accounts_list.json"]
